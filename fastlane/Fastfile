opt_out_usage
fastlane_version '2.220.0'

default_platform :mac

# --- Developer ID signing configuration -----------------------------------
# Keep these values STABLE across every release. macOS ties the Local Network /
# removable-volume privacy (TCC) grant to the code-signing designated
# requirement (identifier + team + certificate); changing any of them makes the
# permission prompt reappear after a `brew upgrade`.
DEVELOPER_ID = 'Developer ID Application: BluDesign, LLC (B88BRQ88KH)'.freeze
DEVELOPER_ID_MATCH_APP_IDENTIFIER = 'com.BluDesign.TartRouter'.freeze

# Release binary (in builds/) => its stable code-signing identifier (bundle ID).
BINARIES = {
  'tart-executor' => 'com.BluDesign.TartExecutor',
  'tart-router' => 'com.BluDesign.TartRouter'
}.freeze

# The App Store Connect API key reaches us as an env var, and secret stores /
# CI env vars routinely mangle the .p8: base64-wrapping the whole file, escaping
# its newlines as the literal characters "\n", or using CRLF. notarytool is
# strict and rejects any of these with `invalidPEMDocument`, so normalize back
# to real PEM before writing the key to disk.
def asc_api_key_pem(raw)
  content = raw.to_s.gsub("\r\n", "\n").strip
  # Single-line secrets often store newlines as the two literal characters \n.
  content = content.gsub('\\n', "\n") unless content.include?("\n")
  # Some stores keep the entire .p8 base64-encoded; decode when it isn't PEM yet.
  unless content.include?('-----BEGIN')
    require 'base64'
    decoded = Base64.decode64(content).gsub("\r\n", "\n").strip
    content = decoded if decoded.include?('-----BEGIN')
  end
  unless content.include?('-----BEGIN')
    UI.user_error!('CONNECT_API_KEY did not resolve to a PEM private key — the Vault ' \
                   'secret must be the raw .p8 text or a base64 encoding of it')
  end
  "#{content}\n"
end

platform :mac do
  # --- Keychain helpers (self-hosted CI runner) ---------------------------

  private_lane :unlock_login_keychain do
    if ENV['KEYCHAIN_PATH']
      unlock_keychain(
        path: ENV['KEYCHAIN_PATH'].to_s,
        password: ENV['KEYCHAIN_PASSWORD'].to_s
      )
    end
  end

  desc 'Creates the CI signing keychain (no-op off CI)'
  lane :create_profile_keychain do
    if ENV['KEYCHAIN_NAME']
      create_keychain(
        name: ENV['KEYCHAIN_NAME'].to_s,
        password: ENV['KEYCHAIN_PASSWORD'].to_s,
        unlock: true,
        timeout: 0
      )
    end
  end

  # --- App Store Connect API key ------------------------------------------

  private_lane :connect_api_key do
    if ENV['CONNECT_API_KEY_ID']
      app_store_connect_api_key(
        key_id: ENV['CONNECT_API_KEY_ID'].to_s.strip,
        issuer_id: ENV['CONNECT_API_ISSUER_ID'].to_s.strip,
        key_content: asc_api_key_pem(ENV['CONNECT_API_KEY']),
        in_house: false
      )
    end
  end

  # --- Developer ID certificate -------------------------------------------

  desc 'Installs the Developer ID Application certificate via match (pass readonly:true on CI)'
  lane :certificates do |options|
    unlock_login_keychain
    connect_api_key
    match_options = {
      type: 'developer_id',
      platform: 'macos',
      readonly: options.fetch(:readonly, true),
      app_identifier: DEVELOPER_ID_MATCH_APP_IDENTIFIER,
      # Bare CLI tools embed no provisioning profile; only the cert + key matter.
      skip_provisioning_profiles: true,
      api_key: lane_context[SharedValues::APP_STORE_CONNECT_API_KEY]
    }
    # On CI, import into the dedicated runner keychain; locally use the default.
    if ENV['KEYCHAIN_NAME']
      match_options[:keychain_name] = ENV['KEYCHAIN_NAME'].to_s
      match_options[:keychain_password] = ENV['KEYCHAIN_PASSWORD'].to_s
    end
    match(match_options)
  end

  # --- Signing & notarization ---------------------------------------------

  desc 'Signs and verifies the release binaries in builds/ with the Developer ID identity'
  lane :sign do
    unlock_login_keychain
    BINARIES.each do |name, identifier|
      binary = "builds/#{name}"
      # --options runtime = hardened runtime, --timestamp = secure timestamp
      # (both required for notarization); --identifier pins the stable bundle ID.
      sh("cd .. && codesign --force --timestamp --options runtime " \
         "--identifier '#{identifier}' --sign '#{DEVELOPER_ID}' '#{binary}'")
      sh("cd .. && codesign --verify --strict --verbose=2 '#{binary}'")
      sh("cd .. && codesign --display --verbose=4 '#{binary}' 2>&1 | " \
         "grep -E 'Identifier|TeamIdentifier|Authority|flags' || true")
    end
  end

  desc 'Notarizes the zipped release binaries (builds/*.zip) with notarytool'
  lane :notarize_binaries do
    # Trim the same way as the key: Vault-stored secrets often carry a trailing
    # newline, and a stray character here becomes part of the JWT kid/iss, which
    # Apple rejects with "401 Unauthenticated".
    key_id = ENV['CONNECT_API_KEY_ID'].to_s.strip
    issuer = ENV['CONNECT_API_ISSUER_ID'].to_s.strip
    if ENV['CONNECT_API_KEY'].to_s.strip.empty? || key_id.empty? || issuer.empty?
      UI.user_error!('CONNECT_API_KEY / CONNECT_API_KEY_ID / CONNECT_API_ISSUER_ID must be set to notarize')
    end
    # Key IDs and issuer UUIDs never contain whitespace; if any survives the
    # strip the secret is mangled beyond a trailing newline, so fail clearly.
    if key_id =~ /\s/ || issuer =~ /\s/
      UI.user_error!('CONNECT_API_KEY_ID / CONNECT_API_ISSUER_ID contain internal whitespace — check the Vault secrets for stray newlines')
    end

    # notarytool wants the App Store Connect key as a file; write it under the
    # git-ignored builds/ dir and remove it once every submission has finished.
    key_path = 'builds/asc_api_key.p8'
    File.write("../#{key_path}", asc_api_key_pem(ENV['CONNECT_API_KEY']))
    begin
      BINARIES.each_key do |name|
        # Bare Mach-O binaries can't be stapled, so we submit and --wait; the
        # notarization ticket is served online, fine for these networked hosts.
        sh("cd .. && xcrun notarytool submit 'builds/#{name}.zip' " \
           "--key '#{key_path}' " \
           "--key-id '#{key_id}' " \
           "--issuer '#{issuer}' " \
           '--wait')
      end
    ensure
      File.delete("../#{key_path}") if File.exist?("../#{key_path}")
    end
  end
end
